#!/usr/bin/env bash
# news-tmux — open the digest in a narrow tmux pane on the right, next to your
# current work (e.g. Claude Code). Degrades gracefully when tmux is absent.
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VIEWER="$DIR/news"

if ! command -v tmux >/dev/null 2>&1; then
  cat <<EOF
tmux is not installed.

You don't need it — Meanwhile runs in any terminal pane. Just open a second
terminal tab/split next to Claude Code and run:

    $VIEWER

(Install tmux for the side-pane layout: 'brew install tmux' or your package manager.)
EOF
  exit 0
fi

# Narrow right-hand pane (~38% width). Inside tmux: split the current window.
if [ -n "${TMUX:-}" ]; then
  tmux split-window -h -l 38% "exec '$VIEWER'"
  tmux select-pane -L   # return focus to your original (left) pane
  echo "Opened Meanwhile in a pane on the right. Focus is back on your pane."
else
  # Outside tmux: create a session with your shell on the left, digest on the right.
  SESSION="meanwhile"
  tmux new-session -d -s "$SESSION"
  tmux split-window -h -l 38% -t "$SESSION" "exec '$VIEWER'"
  tmux select-pane -L -t "$SESSION"
  exec tmux attach -t "$SESSION"
fi
